rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function uploadDoc(uploadId) {
      return firestore.get(/databases/(default)/documents/uploads/$(uploadId)).data;
    }

    function reservedPendingUploadPath(uploadId, fileName) {
      return "customer-uploads/pending/" + uploadId + "/" + fileName;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == "admin";
    }

    match /products/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /customer-uploads/pending/{uploadId}/{fileName} {
      allow read: if isAdmin();
      allow write: if
        request.resource != null &&
        request.resource.size == uploadDoc(uploadId).fileSize &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType != "image/svg+xml" &&
        request.resource.contentType == uploadDoc(uploadId).mimeType &&
        uploadDoc(uploadId).mimeType != "image/svg+xml" &&
        uploadDoc(uploadId).lockedAt == null &&
        uploadDoc(uploadId).storagePath == reservedPendingUploadPath(uploadId, fileName) &&
        uploadDoc(uploadId).reviewStatus == "pending_upload" &&
        uploadDoc(uploadId).linkedOrderId == null &&
        (
          uploadDoc(uploadId).allowGuestUpload == true ||
          (
            isSignedIn() &&
            uploadDoc(uploadId).ownerUid == request.auth.uid
          )
        );
    }

    match /customer-uploads/{orderId}/{itemId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
